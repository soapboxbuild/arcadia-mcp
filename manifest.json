{
  "$schema": "https://raw.githubusercontent.com/anthropics/mcpb/main/schemas/mcpb-manifest-v0.4.schema.json",
  "manifest_version": "0.4",
  "name": "arcadia-arc",
  "display_name": "Arcadia Arc",
  "version": "0.1.0",
  "description": "Utility bill and interval data across 7,000+ utilities with eGRID carbon factors.",
  "author": {
    "name": "Soapbox",
    "url": "https://soapbox.build"
  },
  "homepage": "https://soapbox.build/plugins",
  "server": {
    "type": "node",
    "mcp_config": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://arcadia.mcp.soapbox.build/mcp"
      ]
    }
  },
  "compatibility": {
    "claude_desktop": ">=0.10.0",
    "platforms": [
      "darwin",
      "win32",
      "linux"
    ]
  }
}
